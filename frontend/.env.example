# BakeryOS Frontend — environment variables
# Copy this file to .env.local and fill in the values.

# URL of the BakeryOS backend API (no trailing slash).
# In development the Vite proxy rewrites /api/* so you can leave this blank.
# In production set it to your deployed backend, e.g. https://api.yourdomain.com
VITE_API_URL=

# Google OAuth 2.0 client ID from Google Cloud Console.
# Required for "Sign in with Google" on the login screen.
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=
